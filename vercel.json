{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": { "maxDuration": 60 },
    "api/*/*.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https:; media-src 'self' data: blob: https:; worker-src 'self' blob:; frame-src 'self' https:"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/gpt", "destination": "/gpt.html" },
    { "source": "/chatgpt", "destination": "/gpt.html" },
    { "source": "/stella-gpt", "destination": "/gpt.html" },
    { "source": "/talk", "destination": "/talk.html" },
    { "source": "/stella-talk", "destination": "/talk.html" },
    { "source": "/cloud", "destination": "/cloud.html" },
    { "source": "/stella-cloud", "destination": "/cloud.html" },
    { "source": "/db", "destination": "/db.html" },
    { "source": "/hub", "destination": "/hub.html" },
    { "source": "/stella-hub", "destination": "/hub.html" },
    { "source": "/cc", "destination": "/cc.html" },
    { "source": "/abap", "destination": "/abap.html" },
    { "source": "/stella-abap", "destination": "/abap.html" },
    { "source": "/code", "destination": "/cc.html" },
    { "source": "/stella-code", "destination": "/cc.html" },
    { "source": "/developer", "destination": "/developer.html" },
    { "source": "/restore", "destination": "/restore.html" }
  ]
}
