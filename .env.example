# ============================================================
# Stella AI Workspace — OCI 환경변수 (.env)
# ------------------------------------------------------------
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요.
#   cp .env.example .env  &&  nano .env
#
# ★ 가장 쉬운 방법: 기존 Vercel 프로젝트의 환경변수를 그대로 가져오기
#   - Vercel CLI:  vercel env pull .env     (vercel login 필요)
#   - 또는 Vercel 대시보드 → Settings → Environment Variables 에서 복사
#   Vercel에 이미 동작하는 값들이 다 있으니 그걸 옮기는 게 가장 확실합니다.
#
# ⚠️ .env 는 절대 git 에 커밋하지 마세요 (.gitignore/.dockerignore 에 이미 제외됨)
# ============================================================

# ── AI 모델 ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MEMORY_MODEL=

# ── 메타데이터 DB = OCI 동거 SQL Server (표준) ───────────────
# 실 데이터는 Google Drive. 여기는 검색 인덱스/회원/메모리 등 메타데이터만.
# ★ Azure SQL 은 폐기(deprecated) — 앞으로 메타데이터는 OCI 서버의 stella-mssql 사용.
# 설정: deploy/run-metadata-db-oci.sh 로 stella-mssql 컨테이너 기동 후 아래 지정.
DB_SERVER=stella-mssql
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=
DB_NAME=stella
# 자체서명 인증서 허용(코드가 로컬/사설/컨테이너 호스트는 자동 허용하지만 명시 권장):
DB_TRUST_SERVER_CERT=true
# 순수 로컬에서 TLS 자체를 끄려면(선택): DB_ENCRYPT=false
#
# (레거시/미사용) Azure SQL 로 되돌릴 때만 사용 — connection string 하나로 대체 가능:
# AZURE_SQL_CONNECTION_STRING=

# ── Google (Drive OAuth / Maps / Weather / Custom Search) ────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=https://stella.xn--hu5b23z.com/api/auth/callback
GOOGLE_API_KEY=
GOOGLE_CX=
GOOGLE_MAPS_API_KEY=
GOOGLE_WEATHER_API_KEY=

# ── GitHub (소스 저장/내보내기 연동) ─────────────────────────
GITHUB_TOKEN=
GITHUB_OWNER=yesblue0342-bit
GITHUB_REPO=
GITHUB_BRANCH=main
ALLOWED_REPOS=

# ── 지도/검색 (선택) ─────────────────────────────────────────
KAKAO_REST_API_KEY=
KAKAO_MAP_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 메일 (비밀번호 재설정 등, 선택) ──────────────────────────
RESEND_API_KEY=
MAIL_FROM=

# ── 인증/관리 ────────────────────────────────────────────────
STELLA_ADMIN_PASSWORD=
ADMIN_PASSWORD=
STELLA_MEMBERS=
ALLOWED_ORIGINS=https://stella.xn--hu5b23z.com
PROXY_SECRET=

# ── 기타 ─────────────────────────────────────────────────────
PORT=8970
