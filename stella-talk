<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Stella Talk</title><style>body{margin:0;background:#fff;color:#111;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Noto Sans KR",sans-serif}.dark{background:#0b1120;color:#f8fafc}.box{max-width:820px;height:100vh;margin:auto;display:flex;flex-direction:column;border-left:1px solid #ddd;border-right:1px solid #ddd;background:rgba(255,255,255,var(--op,1))}.dark .box{background:rgba(17,24,39,var(--op,1));border-color:#334155}.head,.tools,.foot{padding:12px;border-bottom:1px solid #e5e7eb;display:flex;gap:8px;align-items:center}.head b{font-size:20px}.spacer{flex:1}button{border:1px solid #d1d5db;background:#fff;border-radius:12px;padding:9px 12px;font-weight:800}.dark button{background:#111827;color:#fff;border-color:#475569}input,textarea{border:1px solid #d1d5db;border-radius:12px;padding:10px;font:inherit}textarea{flex:1;min-height:56px}.msgs{flex:1;overflow:auto;padding:14px;background:#fff}.dark .msgs{background:#0b1120}.msg{max-width:76%;border:1px solid #e5e7eb;border-radius:16px;padding:10px;margin:8px 0;white-space:pre-wrap}.me{margin-left:auto;background:#eef2ff}.dark .me{background:#1f2a44}.meta{font-size:12px;color:#64748b;margin-bottom:4px}.wide{max-width:1120px}.collapsed .tools,.collapsed .msgs,.collapsed .foot{display:none}@media(max-width:700px){.box{border:0}.msg{max-width:90%}}</style></head><body><div id="box" class="box"><div class="head"><b>Stella Talk</b><span class="spacer"></span><button id="fold">접기</button><button id="wide">넓게</button><button id="dark">다크</button></div><div class="tools"><input id="room" value="default-room"><input id="name" value="김경훈"><label>투명도 <input id="op" type="range" min="70" max="100" value="100"></label></div><main id="msgs" class="msgs"></main><div class="foot"><textarea id="text" placeholder="메시지 입력"></textarea><button id="send">전송</button></div></div><script>const box=document.getElementById('box'),msgs=document.getElementById('msgs'),room=document.getElementById('room'),nameEl=document.getElementById('name'),text=document.getElementById('text');let data={messages:[]};function key(){return 'stella-talk-'+room.value}function load(){try{data=JSON.parse(localStorage.getItem(key())||'{"messages":[]}')}catch(e){data={messages:[]}}render()}function save(){localStorage.setItem(key(),JSON.stringify(data))}function render(){msgs.innerHTML='';data.messages.forEach(m=>{const d=document.createElement('div');d.className='msg '+(m.sender===nameEl.value?'me':'');const meta=document.createElement('div');meta.className='meta';meta.textContent=(m.sender||'user')+' · '+new Date(m.createdAt||Date.now()).toLocaleString();const bd=document.createElement('div');bd.textContent=m.message||'';d.appendChild(meta);d.appendChild(bd);msgs.appendChild(d)});msgs.scrollTop=msgs.scrollHeight}async function send(){const v=text.value.trim();if(!v)return;data.messages.push({sender:nameEl.value||'user',message:v,createdAt:new Date().toISOString()});text.value='';save();render();try{await fetch('/api/member-chat-save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({roomId:room.value,title:room.value,sender:nameEl.value,message:v,messages:data.messages.slice(0,-1)})})}catch(e){}}document.getElementById('send').onclick=send;document.getElementById('fold').onclick=()=>box.classList.toggle('collapsed');document.getElementById('wide').onclick=()=>box.classList.toggle('wide');document.getElementById('dark').onclick=()=>document.body.classList.toggle('dark');document.getElementById('op').oninput=e=>document.documentElement.style.setProperty('--op',e.target.value/100);room.onchange=load;load();</script></body></html>